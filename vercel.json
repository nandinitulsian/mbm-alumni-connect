{
    "version": 2,
    "builds": [
        {
            "src": "core/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.12",
                "installCommand": "pip install asgiref==3.8.1 dj-database-url==3.1.2 Django==6.0.3 gunicorn==23.0.0 Pillow==11.1.0 python-decouple==3.8 sqlparse==0.5.5 tzdata==2025.3 whitenoise==6.9.0"
            }
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "core/wsgi.py"
        }
    ]
}